<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>MacClock</title>
    <organization>com.tapnetix</organization>
    <welcome file="welcome.html" mime-type="text/html" />
    <license file="LICENSE.txt" mime-type="text/plain" />
    <conclusion file="conclusion.html" mime-type="text/html" />
    <volume-check>
        <allowed-os-versions>
            <os-version min="14.0" />
        </allowed-os-versions>
    </volume-check>
    <options customize="never" require-scripts="true" rootVolumeOnly="true" />
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true" />
    <choices-outline>
        <line choice="default">
            <line choice="com.tapnetix.MacClock" />
        </line>
    </choices-outline>
    <choice id="default" />
    <choice id="com.tapnetix.MacClock" visible="false">
        <pkg-ref id="com.tapnetix.MacClock" />
    </choice>
    <pkg-ref id="com.tapnetix.MacClock" onConclusion="none">MacClock-component.pkg</pkg-ref>
</installer-gui-script>
